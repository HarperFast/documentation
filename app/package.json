{
	"name": "@harperdb/docs-site",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"description": "Harper-native documentation site: ingest, serving, search, chat (replatform of docs.harperdb.io)",
	"scripts": {
		"sync-static": "rm -rf web/img web/js && cp -R ../static/img web/img && cp -R ../static/js web/js",
		"predev": "npm run sync-static",
		"dev": "HOME=/Users/kyle/hdb-docs-replatform ROOTPATH=/Users/kyle/hdb-docs-replatform/hdb harper dev .",
		"local:start": "HOME=/Users/kyle/hdb-docs-replatform ROOTPATH=/Users/kyle/hdb-docs-replatform/hdb harper start",
		"local:stop": "HOME=/Users/kyle/hdb-docs-replatform ROOTPATH=/Users/kyle/hdb-docs-replatform/hdb harper stop",
		"local:status": "HOME=/Users/kyle/hdb-docs-replatform ROOTPATH=/Users/kyle/hdb-docs-replatform/hdb harper status",
		"typecheck": "tsc --noEmit",
		"test": "node --test test/unit/*.test.ts",
		"test:integration": "node --test test/integration/*.test.ts",
		"test:e2e": "node --test test/e2e/*.test.ts",
		"test:all": "npm run test && npm run test:integration && npm run test:e2e",
		"ingest": "node scripts/ingest.ts",
		"parity": "node scripts/parity.ts",
		"search-eval": "node scripts/search-eval.ts"
	},
	"dependencies": {
		"@harperfast/oauth": "^2.1.2",
		"gray-matter": "^4.0.3",
		"rehype-raw": "^7.0.0",
		"rehype-slug": "^6.0.0",
		"rehype-stringify": "^10.0.1",
		"remark-directive": "^4.0.0",
		"remark-gfm": "^4.0.1",
		"remark-parse": "^11.0.0",
		"remark-rehype": "^11.1.1",
		"unified": "^11.0.5",
		"unist-util-visit": "^5.0.0"
	},
	"devDependencies": {
		"node-html-parser": "^8.0.4",
		"playwright": "^1.61.1",
		"typescript": "^6.0.3"
	}
}
